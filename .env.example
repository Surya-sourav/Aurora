# Postgres (Neon serverless)
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=

# Server
NODE_ENV=development
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=replace-with-a-32+-char-random-string
JWT_EXPIRES_IN=7d

# Admin seed
# Generate the password hash with:
#   node -e "console.log(require('bcrypt').hashSync('your-password', 12))"
ADMIN_NAME=Surya
ADMIN_EMAIL=surya@finlens.app
ADMIN_PASSWORD_HASH=
